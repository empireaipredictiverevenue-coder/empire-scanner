<div class="max-w-6xl mx-auto mt-8 pb-20">
    <div class="bg-slate-900 p-6 rounded-3xl border border-slate-800 neon-glow">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-sm font-bold text-green-500 uppercase tracking-widest">Intelligence HUD</h2>
            <button onclick="syncHUD()" class="bg-slate-800 hover:bg-slate-700 text-[10px] px-4 py-2 rounded-full border border-slate-700 transition-all uppercase font-bold">Sync Latest Data</button>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left text-[11px] font-mono">
                <thead>
                    <tr class="text-slate-500 border-b border-slate-800">
                        <th class="pb-3 px-2">TARGET</
                        <th class="pb-3 px-2">NICHE</th>
                        <th class="pb-3 px-2 text-green-500">GROWTH PLAN / HOOK</th>
                    </tr>
                </thead>
                <tbody id="hudBody" class="divide-y divide-slate-800/50">
                    <tr>
                        <td colspan="3" class="py-10 text-center text-slate-600 italic">No intelligence synced yet...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</async function syncHUD() {
    const hud = document.getElementById('hudBody');
    hud.innerHTML = '<tr><td colspan="3" class="py-10 text-center text-yellow-500 animate-pulse uppercase">Syncing with Empire Database...</td></tr>';
    
    try {
        // https://api.steinhq.com/v1/storages/69dd55e63807a370b048991d
        const response = await fetch('YOUR_RESULTS_API_URL'); 
        const data = await response.json();
        
        hud.innerHTML = "";
        data.slice(0, 5).forEach(row => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="py-4 px-2 font-bold text-white">${row.businessName}</td>
                <td class="py-4 px-2 text-slate-400">${row.niche}</td>
                <td class="py-4 px-2 text-green-400 italic">"${row.hook}"</td>
            `;
            hud.prepend(tr);
        });
    } catch (err) {
        hud.innerHTML = '<tr><td colspan="3" class="py-10 text-center text-red-500 uppercase">Sync Failed. Check API Connection.</td></tr>';
    }
}

<div class="max-w-6xl mx-auto mt-8 pb-20">
    <div class="bg-slate-900 p-6 rounded-3xl border border-slate-800 shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-sm font-bold text-green-500 uppercase tracking-widest">Empire Intelligence HUD</h2>
            <button onclick="syncHUD()" class="bg-slate-800 hover:bg-slate-700 text-[10px] px-4 py-2 rounded-full border border-slate-700 transition-all font-bold uppercase">Sync HUD</button>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-[11px] font-mono">
                <thead>
                    <tr class="text-slate-500 border-b border-slate-800">
                        <th class="pb-3 px-2">TARGET</th>
                        <th class="pb-3 px-2">NICHE</th>
                        <th class="pb-3 px-2 text-green-500">MANUS STRATEGY / HOOK</th>
                    </tr>
                </thead>
                <tbody id="hudBody" class="divide-y divide-slate-800/50">
                    <tr>
                        <td colspan="3" class="py-10 text-center text-slate-600 italic">No intelligence synced yet. Hit Sync to refresh.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
async function syncHUD() {
    const hud = document.getElementById('hudBody');
    hud.innerHTML = '<tr><td colspan="3" class="py-10 text-center text-yellow-500 animate-pulse">CONNECTING TO EMPIRE DATABASE...</td></tr>';
    
    try {
        // Replace 'YOUR_SHEET_JSON_URL' with your Google Sheet API or Webhook URL
        const response = await fetch('YOUR_SHEET_JSON_URL'); 
        const data = await response.json();
        
        hud.innerHTML = "";
        data.slice(0, 5).forEach(row => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td class="py-4 px-2 font-bold text-white">${row.businessName}</td>
                <td class="py-4 px-2 text-slate-400">${row.niche}</td>
                <td class="py-4 px-2 text-green-400 italic">"${row.hook}"</td>
            `;
            hud.prepend(tr);
        });
    } catch (err) {
        hud.innerHTML = '<tr><td colspan="3" class="py-10 text-center text-red-500">SYNC FAILED. CHECK API CONNECTION.</td></tr>';
    }
}


